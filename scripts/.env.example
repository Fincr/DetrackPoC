# Copy to scripts/.env and fill in the real values. scripts/.env is gitignored.
# Used by forward_gw_events.py (ePOD -> GWOptical tracking forwarder).

# ePOD Supabase — Session Pooler URI (Dashboard -> Project Settings -> Database
# -> Connection string -> Session pooler). IPv4-compatible; the `postgres` role
# bypasses RLS, which the forwarder needs to read parcel_events/pod_records and
# write gw_forward_log. Project ref: mqiwyfhxcjvkpnpbtgql (eu-west-2).
EPOD_DATABASE_URL=postgresql://postgres.mqiwyfhxcjvkpnpbtgql:[YOUR-DB-PASSWORD]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres

# GWOptical (SQL Server) intake. Same connection string Lens uses — copy the
# GWOPTICAL_CONN value from specsavers-report/scripts/.env. Wrap the password in
# {braces} if it contains ODBC-special characters. MultiSubnetFailover=Yes is
# required (sqlaggw is an AG listener — see specsavers-report .env.example).
GWOPTICAL_CONN=Driver={ODBC Driver 18 for SQL Server};Server=tcp:sqlaggw.citipost.co.uk,8889;MultiSubnetFailover=Yes;Database=GWOptical;UID=gwoptical;PWD={...};Encrypt=no;TrustServerCertificate=yes

# Per-carrier CarrierProviderName + CarrierCode now live in forward_gw_events.py
# (CARRIER_RULES), verified against CarrierHub's code master — no env config.
# Carrier is derived from the tracking-number prefix (I2IAD->I2I, I2IOA->Oceanair,
# 7086->DX, else->DHL Parcel UK). Oceanair is suppressed until Audrius gives codes.
